    "scripts":  {
                    "dev":  "next dev",
                    "build":  "next build",
                    "start":  "next start",
                    "lint":  "eslint",
                    "test":  "vitest",
                    "test:run":  "vitest run",
                    "test:coverage":  "vitest run --coverage",
